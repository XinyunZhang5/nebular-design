# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://nebular:nebular@localhost:5432/nebulardb

# JWT
SECRET_KEY=change-this-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=sk-ant-...

# AWS S3
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=nebular-design-uploads
# Set to false to save files locally instead of S3 (for development)
USE_S3=false

# Depth Estimation (DepthAnything V2)
# Set to false to skip model download (useful in CI / low-memory envs)
ENABLE_DEPTH_ESTIMATION=true
DEPTH_MODEL=depth-anything/Depth-Anything-V2-Small-hf

# CORS
FRONTEND_URL=http://localhost:3000
